<!DOCTYPE html>
<html lang="en">
<head>
	{{>head}}
</head>

<body>
	<div class="container">
		<div class="left-container">
			<div class="auth-form">
				<h2>Create Account</h2>
				<hr>
				<form id="registerForm" method="post">
					<div class="input-wrapper">
						<i class="fa-solid fa-id-badge"></i>
						<div class="name-field">
							<input type="text" id="first-name" name="first-name" class="custom-input" placeholder="First Name">
							<input type="text" id="last-name" name="last-name" class="custom-input" placeholder="Last Name">
						</div>
					</div>

					<div class="input-wrapper">
						<i class="fa-solid fa-envelope"></i>
						<input type="email" id="email" name="email" class="custom-input" placeholder="Email">
					</div>
					<div class="input-wrapper">
						<i class="fa-solid fa-lock"></i>
						<input type="password" id="password" name="password" class="custom-input" placeholder="Password">
					</div>
					<div class="input-wrapper">
						<i class="fa-solid fa-key"></i>
						<input type="password" id="confirm-password" name="confirm-password" class="custom-input" placeholder="Confirm Password">
					</div>
					<div class="input-wrapper">
						<label for="type">I am a ...</label>
						<select id="type" name="type" class="custom-select" placeholder="Student/Lab Technician">
							<option value="student">Student</option>
							<option value="lab-technician">Lab Technician</option>
						</select>
					</div>
					<button type="submit" class="btn-primary">Sign Up</button>
				</form>

				<hr>
				<p>Already have an account? <a href="/login">Login Here</a></p>
			</div>
		</div>

		<div class="right-container">
			<div class="header-text">
				<span class="subtext">just three steps:</span>
				<h1>Register <br> <span class="accent">Login</span> <br>Reserve</h1>
			</div>
		</div>
	</div>

	{{>scripts includeData=true pageScript="auth.js"}}
</body>
</html>
